{
  "name": "coderelay",
  "version": "0.0.0-m2-proof",
  "private": true,
  "description": "Subscription-only, policy-enforced orchestration between the official Codex and Claude Code CLIs.",
  "type": "module",
  "main": "dist/src/app/main.js",
  "engines": {
    "node": "24.14.1"
  },
  "scripts": {
    "build": "npm run build:typescript && npm run build:mcp",
    "build:preload": "esbuild src/app/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/app/preload.cjs",
    "build:renderer": "esbuild src/app/renderer/index.tsx --bundle --format=iife --jsx=automatic --outfile=dist/app/renderer/index.js && node -e \"require('fs').copyFileSync('src/app/renderer/index.html','dist/app/renderer/index.html')\"",
    "build:app": "npm run build && npm run build:preload && npm run build:renderer",
    "app": "npm run build:app && electron .",
    "build:typescript": "tsc -p tsconfig.json",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --platform=node --format=esm --target=node24 --outfile=dist/mcp-server.mjs --sourcemap --legal-comments=external",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test",
    "preprobe": "npm run build",
    "probe": "tsx src/cli.ts probe",
    "prototype": "tsx src/cli.ts prototype",
    "premilestone2": "npm run build",
    "milestone2": "tsx src/cli.ts milestone2",
    "utility": "tsx src/orchestrator/utility-process.ts",
    "audit:dependencies": "npm audit --audit-level=high",
    "sbom": "cyclonedx-npm --output-file evidence/sbom.cdx.json --output-format JSON --spec-version 1.6"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-npm": "^6.0.0",
    "@types/node": "^24.0.15",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.1",
    "esbuild": "0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
